# Neon PostgreSQL connection string
# Get this from https://neon.tech -> your project -> Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret for signing JWT sessions (minimum 32 random characters)
# Generate one with: openssl rand -base64 32
SESSION_SECRET="replace-this-with-a-long-random-secret-of-32-characters-or-more"

# Allowed origins for Server Actions, comma-separated
ALLOWED_ORIGINS="localhost:3000"

# Cloudflare R2
# Account ID -> Cloudflare dashboard -> R2 -> Overview
R2_ACCOUNT_ID="your_account_id"
# API Token -> R2 -> Manage R2 API Tokens -> Create token (Object Read & Write)
R2_ACCESS_KEY_ID="your_access_key_id"
R2_SECRET_ACCESS_KEY="your_secret_access_key"
# Bucket name (must already exist in R2) - keep it private, no public access needed
R2_BUCKET_NAME="insumed"

# Optional seed admin user
SEED_ADMIN_NAME="Administrador"
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="change-this-for-a-long-unique-password"
